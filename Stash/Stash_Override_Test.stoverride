  - DOMAIN-SUFFIX,meituan.net,DIRECT
  - DOMAIN-SUFFIX,sankuai.com,DIRECT
  - DOMAIN-SUFFIX,meituanwaimai.com,DIRECT
  - DOMAIN-SUFFIX,meituanzhongbao.com,DIRECT
  - DOMAIN-SUFFIX,meituanpay.com,DIRECT
  - DOMAIN-SUFFIX,meituanmail.com,DIRECT
  - DOMAIN-SUFFIX,meituanimg.com,DIRECT
  - DOMAIN-SUFFIX,mtcdn.cn,DIRECT
  - DOMAIN-SUFFIX,dpfile.com,DIRECT
  - DOMAIN-SUFFIX,dianping.com,DIRECT
  - DOMAIN-SUFFIX,dianping.cn,DIRECT
  # Kugou
  - DOMAIN-SUFFIX,kugou.com,DIRECT
  - DOMAIN-SUFFIX,kugou.net,DIRECT
  - DOMAIN-SUFFIX,kgimg.com,DIRECT
  - DOMAIN-SUFFIX,kglink.cn,DIRECT
  - DOMAIN-SUFFIX,kugouaudio.com,DIRECT
  - DOMAIN-SUFFIX,kugoustore.com,DIRECT
  - DOMAIN-SUFFIX,kugouvoice.com,DIRECT
  - DOMAIN-SUFFIX,kugouyouth.com,DIRECT
  # China Mobile
  - DOMAIN-SUFFIX,10086.cn,DIRECT
  - DOMAIN-SUFFIX,10099.com.cn,DIRECT
  - DOMAIN-SUFFIX,cmpassport.com,DIRECT
  - DOMAIN-SUFFIX,139.com,DIRECT
  - DOMAIN-SUFFIX,and.10086.cn,DIRECT
  - DOMAIN-SUFFIX,andlink.cn,DIRECT
  - DOMAIN-SUFFIX,andlink.com,DIRECT
  # China Telecom
  - DOMAIN-SUFFIX,189.cn,DIRECT
  - DOMAIN-SUFFIX,chinatelecom.com.cn,DIRECT
  - DOMAIN-SUFFIX,21cn.com,DIRECT
  # Xiaomi Home
  - DOMAIN-SUFFIX,xiaomi.com,DIRECT
  - DOMAIN-SUFFIX,io.mi.com,DIRECT
  - DOMAIN-SUFFIX,miot.com,DIRECT
  - DOMAIN-SUFFIX,miot-spec.com,DIRECT
  # Midea Home
  - DOMAIN-SUFFIX,midea.com,DIRECT
  - DOMAIN-SUFFIX,smartmidea.net,DIRECT
  # Baidu
  - DOMAIN-SUFFIX,baidu.com,DIRECT
  - DOMAIN-SUFFIX,bdstatic.com,DIRECT
  - DOMAIN-SUFFIX,bcebos.com,DIRECT
  # NetEase Mail
  - DOMAIN-SUFFIX,126.com,DIRECT
  - DOMAIN-SUFFIX,163.com,DIRECT
  - DOMAIN-SUFFIX,126.net,DIRECT
  - DOMAIN-SUFFIX,netease.com,DIRECT
  # UnionPay
  - DOMAIN-SUFFIX,95516.com,DIRECT
  - DOMAIN-SUFFIX,unionpay.com,DIRECT
  - DOMAIN-SUFFIX,unionpayintl.com,DIRECT
  # Alibaba Ecosystem
  - DOMAIN-SUFFIX,taobao.com,DIRECT
  - DOMAIN-SUFFIX,tmall.com,DIRECT
  - DOMAIN-SUFFIX,alibaba.com,DIRECT
  - DOMAIN-SUFFIX,alibabacloud.com,DIRECT
  - DOMAIN-SUFFIX,aliyun.com,DIRECT
  - DOMAIN-SUFFIX,aliyuncs.com,DIRECT
  - DOMAIN-SUFFIX,aliyundrive.com,DIRECT
  - DOMAIN-SUFFIX,alipan.com,DIRECT
  - DOMAIN-SUFFIX,alicdn.com,DIRECT
  - DOMAIN-SUFFIX,aliapp.org,DIRECT
  - DOMAIN-SUFFIX,alipay.com,DIRECT
  - DOMAIN-SUFFIX,alipayobjects.com,DIRECT
  - DOMAIN-SUFFIX,antgroup.com,DIRECT
  - DOMAIN-SUFFIX,ele.me,DIRECT
  - DOMAIN-SUFFIX,eleme.cn,DIRECT
  - DOMAIN-SUFFIX,eleme.io,DIRECT
  - DOMAIN-SUFFIX,eleme.net,DIRECT
  # (Taobao Flash Sale / Local Services)
  - DOMAIN-SUFFIX,taobaocdn.com,DIRECT
  - DOMAIN-SUFFIX,tbcdn.cn,DIRECT
  - DOMAIN-SUFFIX,mmstat.com,DIRECT
  - DOMAIN-SUFFIX,umeng.com,DIRECT
  #=========End of custom rules=========#

  #Bottom-up strategy
  - RULE-SET,ChinaMax,DIRECT
  - GEOIP,LAN,DIRECT
  - GEOIP,CN,DIRECT,no-resolve
  - MATCH,PROXY-Gate

rule-providers: #!replace
  AdvertisingLite:
    behavior: domain
    format: yaml
    interval: 86400
    url: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/AdvertisingLite/AdvertisingLite_Domain.yaml

  Privacy:
    behavior: domain
    format: yaml
    interval: 86400
    url: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Privacy/Privacy_Domain.yaml

  ACL4SSR_BanAD:
    behavior: domain
    format: mrs
    interval: 86400
    url: https://raw.githubusercontent.com/ACL4SSR/ACL4SSR/master/Clash/mrs/BanAD_domain.mrs

  ACL4SSR_BanProgramAD:
    behavior: domain
    format: mrs
    interval: 86400
    url: https://raw.githubusercontent.com/ACL4SSR/ACL4SSR/master/Clash/mrs/BanProgramAD_domain.mrs

  ChinaMax:
    behavior: domain
    format: yaml
    interval: 86400
    url: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/ChinaMax/ChinaMax_Domain.yaml

