name: Stash Beta Override
category: Beta

desc: |-
  DNS｜Proxy Groups｜Rules
  Version: 2.7｜2026-07-17
  Encrypted DNS:
   - DoH｜IPv6｜IPv4
  Policy Groups:
   - PROXY-Gate｛Custom/US/SG/HK/KR/JP/CA/EUR(UK-DE-FR-IT-NL)}
  Rules:
   - Customize｜CN
   - MATCH -> PROXY-Gate (Default Fallback)

#!override

mixed-port: 7890
allow-lan: true
bind-address: '*'
mode: rule
log-level: info
external-controller: ':9090'
unified-delay: true
tcp-concurrent: true

#===C30===#
tun: #!replace
  enable: true
  stack: gvisor
  auto-route: true
  auto-detect-interface: true
  dns-hijack:
    - any:53

dns: #!replace
  enable: true
  respect-rules: true
  ipv6: true
  prefer-h3: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16

  default-nameserver:
    - 223.5.5.5
    - 119.29.29.29
    - 2400:3200::1

  nameserver:
    - https://dns.cloudflare.com/dns-query
    - https://dns.google/dns-query
    - https://dns.quad9.net/dns-query

#===The following commands may be invalid===#
  proxy-server-nameserver:
    - tls://1.1.1.1:853
    - tls://8.8.8.8:853
    - tls://9.9.9.9:853

  direct-nameserver:
    - https://dns.alidns.com/dns-query
    - https://doh.pub/dns-query

  direct-nameserver-follow-policy: true

  nameserver-policy:
    'dns.cloudflare.com': ['1.1.1.1', '1.0.0.1']
    'dns.google': ['8.8.8.8', '8.8.4.4']
    'dns.quad9.net': ['9.9.9.9', '149.112.112.112']
    'dns.alidns.com': ['223.5.5.5', '223.6.6.6']
    'doh.pub': ['1.12.12.12', '120.53.53.53']
    '+.ctcxianyu.com': ['https://38.76.213.238:8080/dns-query']
    '+.525536.xyz': ['https://38.76.213.238:8080/dns-query']
    '+.t11-a.app': ['https://dns.alidns.com/dns-query', 'https://doh.pub/dns-query']
    '+.t202511-n.icu': ['https://dns.alidns.com/dns-query', 'https://doh.pub/dns-query']
    '+.163.com': ['https://dns.alidns.com/dns-query']
    '+.126.com': ['https://dns.alidns.com/dns-query']
    '+.126.net': ['https://dns.alidns.com/dns-query']
    '+.netease.com': ['https://dns.alidns.com/dns-query']

  fallback:
    - https://dns.cloudflare.com/dns-query
    - https://dns.google/dns-query
    - https://dns.quad9.net/dns-query

  fallback-filter:
    geoip: true
    geoip-code: CN
    ipcidr:
      - 240.0.0.0/4

  fake-ip-filter:
    - '*.lan'
    - '*.local'
    - 'localhost'
    - '*.msftconnecttest.com'
    - '*.msftncsi.com'
    - '*.msidentity.com'
    - 'captive.apple.com'
    - 'stun.*'
    - '+.stun.*.*'
    - '+.stun.*.*.*'
    - '+.stun.*.*.*.*'
    - '+.stun.*.*.*.*.*'
    - '+.weixin.com'
    - '+.wechat.com'
    - '+.qq.com'
    - '+.tencent.com'
    - 'speedtest.net'

profile: #!replace
  store-selected: true
  store-fake-ip: true

#-------------------#
# proxies: #
#-------------------#
proxy-groups: #!replace
  - name: PROXY-Gate
    type: select
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Final.png
    proxies:
      - 🌎 Custom-Manual
      - 🗺️ EUR-Manual
      - 🇺🇸 US-Auto
      - 🇸🇬 SG-Auto
      - 🇭🇰 HK-Auto
      - 🇯🇵 JP-Auto
      - 🇰🇷 KR-Auto-F
      - 🇨🇦 CA-Auto-F
      - DIRECT

  - name: 🌎 Custom-Manual
    type: select
    include-all: true
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Global.png

  - name: 🗺️ EUR-Manual
    type: select
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Europe_Map.png
    proxies:
      - 🇬🇧 UK-Auto-F
      - 🇩🇪 DE-Auto-F
      - 🇫🇷 FR-Auto-F
      - 🇮🇹 IT-Auto-F
      - 🇳🇱 NL-Auto-F

  - name: 🇺🇸 US-Auto
    type: url-test
    include-all: true
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/United_States.png
    filter: '(?i)(\[US\]|^US$|USA|United States|\bUS\b|美国)'
    url: http://www.gstatic.com/generate_204
    interval: 600
    timeout: 15
    tolerance: 50

  - name: 🇸🇬 SG-Auto
    type: url-test
    include-all: true
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Singapore.png
    filter: '(?i)(\[SG\]|^SG$|Singapore|\bSG\b|新加坡|狮城)'
    url: http://www.gstatic.com/generate_204
    interval: 900
    timeout: 15
    tolerance: 50

  - name: 🇭🇰 HK-Auto
    type: url-test
    include-all: true
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Hong_Kong.png
    filter: '(?i)(\[HK\]|^HK$|Hong Kong|\bHK\b|香港|🇨🇳香港)'
    url: http://www.gstatic.com/generate_204
    interval: 900
    timeout: 15
    tolerance: 50

  - name: 🇯🇵 JP-Auto
    type: url-test
    include-all: true
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Japan.png
    filter: '(?i)(\[JP\]|^JP$|Japan|\bJP\b|日本|东京|大阪|🇯🇵日本)'
    url: http://www.gstatic.com/generate_204
    interval: 900
    timeout: 15
    tolerance: 50

  - name: 🇰🇷 KR-Auto-F
    type: fallback
    include-all: true
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Korea.png
    filter: '(?i)(\[KR\]|^KR$|Korea|South Korea|\bKR\b|韩国|首尔|Seoul)'
    url: http://www.gstatic.com/generate_204
    interval: 900
    timeout: 15
    tolerance: 50

  - name: 🇨🇦 CA-Auto-F
    type: fallback
    include-all: true
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Canada.png
    filter: '(?i)(\[CA\]|^CA$|Canada|加拿大|Toronto|Vancouver|Montreal)'
    url: http://www.gstatic.com/generate_204
    interval: 900
    timeout: 15
    tolerance: 50

  #EUR-Manual
  - name: 🇬🇧 UK-Auto-F
    type: fallback
    include-all: true
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Europe_Map.png
    filter: '(?i)(?!.*Ukraine)(\[UK\]|^UK$|United Kingdom|Britain|\bUK\b|英国|伦敦)'
    url: http://www.gstatic.com/generate_204
    interval: 900
    timeout: 15
    tolerance: 50

  - name: 🇩🇪 DE-Auto-F
    type: fallback
    include-all: true
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Europe_Map.png
    filter: '(?i)(\[DE\]|^DE$|Germany|Deutschland|\bDE\b|德国|法兰克福)'
    url: http://www.gstatic.com/generate_204
    interval: 900
    timeout: 15
    tolerance: 50

  - name: 🇫🇷 FR-Auto-F
    type: fallback
    include-all: true
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Europe_Map.png
    filter: '(?i)(\[FR\]|^FR$|France|\bFR\b|法国|巴黎)'
    url: http://www.gstatic.com/generate_204
    interval: 900
    timeout: 15
    tolerance: 50

  - name: 🇮🇹 IT-Auto-F
    type: fallback
    include-all: true
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Europe_Map.png
    filter: '(?i)(\[IT\]|^IT$|Italy|Italian|\bIT\b|意大利|米兰|罗马|Milan|Rome)'
    url: http://www.gstatic.com/generate_204
    interval: 900
    timeout: 15
    tolerance: 50

  - name: 🇳🇱 NL-Auto-F
    type: fallback
    include-all: true
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Europe_Map.png
    filter: '(?i)(\[NL\]|^NL$|Netherlands|Holland|\bNL\b|荷兰|阿姆斯特丹|Amsterdam)'
    url: http://www.gstatic.com/generate_204
    interval: 900
    timeout: 15
    tolerance: 50

rules: #!replace

  #GitHub
  - DOMAIN-SUFFIX,github.com,PROXY-Gate
  - DOMAIN-SUFFIX,githubusercontent.com,PROXY-Gate
  - DOMAIN-SUFFIX,githubassets.com,PROXY-Gate
  - DOMAIN-SUFFIX,raw.githubusercontent.com,PROXY-Gate
  #Local area network and e-mail
  - IP-CIDR,192.168.0.0/16,DIRECT,no-resolve
  - IP-CIDR,10.0.0.0/8,DIRECT,no-resolve
  - IP-CIDR,172.16.0.0/12,DIRECT,no-resolve
  - IP-CIDR,127.0.0.0/8,DIRECT,no-resolve
  - GEOIP,LAN,DIRECT,no-resolve
  - DST-PORT,465,DIRECT
  - DST-PORT,587,DIRECT
  - DST-PORT,993,DIRECT
  - DST-PORT,995,DIRECT
  #Remote rule set
  - RULE-SET,AdvertisingLite,REJECT
  - RULE-SET,Privacy,REJECT
  - RULE-SET,ACL4SSR_BanAD,REJECT
  - RULE-SET,ACL4SSR_BanProgramAD,REJECT

  #=========Custom rules=========#

  # Apple
  # (Basic connection and time)
  - DOMAIN,time.apple.com,DIRECT
  - DOMAIN,captive.apple.com,DIRECT
  # (Media and content)
  - DOMAIN-SUFFIX,mzstatic.com,PROXY-Gate
  - DOMAIN-SUFFIX,aaplimg.com,PROXY-Gate
  - DOMAIN-SUFFIX,music.apple.com,DIRECT
  # (Storage and backup)
  - DOMAIN-SUFFIX,icloud.com.cn,DIRECT
  - DOMAIN-SUFFIX,icloud.com,DIRECT
  - DOMAIN-SUFFIX,icloud-content.com,DIRECT
  - DOMAIN-SUFFIX,apple-cloudkit.com,DIRECT
  - DOMAIN,gateway.icloud.com,DIRECT
  # (Download and update)
  - DOMAIN-SUFFIX,swcdn.apple.com,PROXY-Gate
  - DOMAIN-SUFFIX,updates.cdn-apple.com,PROXY-Gate
  # (Push service)
  - DOMAIN-SUFFIX,push.apple.com,PROXY-Gate
  - DOMAIN-SUFFIX,push-apple.com.akadns.net,PROXY-Gate
  - DOMAIN-KEYWORD,apple.com.edgekey.net,PROXY-Gate
  - IP-CIDR,17.249.0.0/16,PROXY-Gate,no-resolve
  - IP-CIDR,17.252.0.0/16,PROXY-Gate,no-resolve
  - IP-CIDR,17.57.144.0/22,PROXY-Gate,no-resolve
  - IP-CIDR,17.188.128.0/18,PROXY-Gate,no-resolve
  - IP-CIDR,17.188.20.0/23,PROXY-Gate,no-resolve
  - IP-CIDR6,2620:149:a44::/48,PROXY-Gate,no-resolve
  - IP-CIDR6,2403:300:a42::/48,PROXY-Gate,no-resolve
  - IP-CIDR6,2403:300:a51::/48,PROXY-Gate,no-resolve
  - IP-CIDR6,2a01:b740:a42::/48,PROXY-Gate,no-resolve
  # (App Store / iTunes)
  - DOMAIN,itunes.apple.com,PROXY-Gate
  - DOMAIN-SUFFIX,apps.apple.com,PROXY-Gate
  - DOMAIN-SUFFIX,itunes.apple.com,PROXY-Gate
  - DOMAIN-SUFFIX,appstore.com,PROXY-Gate
  - DOMAIN-KEYWORD,buy.itunes,PROXY-Gate
  - DOMAIN,bag.itunes.apple.com,PROXY-Gate
  - DOMAIN,storekit.itunes.apple.com,PROXY-Gate
  # Microsoft
  - DOMAIN-KEYWORD,copilot,PROXY-Gate
  - DOMAIN-SUFFIX,bing.com,PROXY-Gate
  - DOMAIN-SUFFIX,bingapis.com,PROXY-Gate
  - DOMAIN-SUFFIX,designer.microsoft.com,PROXY-Gate
  - DOMAIN-SUFFIX,copilot.microsoft.com,PROXY-Gate
  - DOMAIN-SUFFIX,ai.microsoft.com,PROXY-Gate
  - DOMAIN,officeapps.live.com,PROXY-Gate
  - DOMAIN,onedrive.live.com,PROXY-Gate
  - DOMAIN-SUFFIX,1drv.com,PROXY-Gate
  - DOMAIN-SUFFIX,sharepoint.com,PROXY-Gate
  - DOMAIN-SUFFIX,office.net,PROXY-Gate
  - DOMAIN-SUFFIX,office365.com,PROXY-Gate
  - DOMAIN-SUFFIX,spoprod-a.akamaihd.net,PROXY-Gate
  - DOMAIN-SUFFIX,mp.microsoft.com,PROXY-Gate
  - DOMAIN-SUFFIX,xboxlive.com,PROXY-Gate
  - DOMAIN-SUFFIX,storeedgefd.dsx.mp.microsoft.com,PROXY-Gate
  - DOMAIN-SUFFIX,dl.delivery.mp.microsoft.com,PROXY-Gate
  - DOMAIN-SUFFIX,displaycatalog.mp.microsoft.com,PROXY-Gate
  - DOMAIN-SUFFIX,assets1.xboxlive.com,PROXY-Gate
  - DOMAIN-SUFFIX,login.live.com,PROXY-Gate
  - DOMAIN-SUFFIX,login.microsoftonline.com,PROXY-Gate
  - DOMAIN-SUFFIX,account.live.com,PROXY-Gate
  - DOMAIN,storage.live.com,DIRECT
  - DOMAIN-KEYWORD,skyapi,DIRECT
  - DOMAIN-SUFFIX,onedrive.com,DIRECT
  - DOMAIN-SUFFIX,outlook.com,DIRECT
  - DOMAIN-SUFFIX,office.com,DIRECT
  - DOMAIN-SUFFIX,msauth.net,DIRECT
  # Tiktok
  - DOMAIN-KEYWORD,snssdk,PROXY-Gate
  - DOMAIN-KEYWORD,amemv,PROXY-Gate
  - DOMAIN-KEYWORD,douyin,PROXY-Gate
  - DOMAIN-KEYWORD,byteimg,PROXY-Gate
  - DOMAIN-KEYWORD,pstatp,PROXY-Gate
  - DOMAIN-KEYWORD,bytedance,PROXY-Gate
  # Wechat
  - DOMAIN-SUFFIX,weixin.qq.com,DIRECT
  - DOMAIN-SUFFIX,wechat.com,DIRECT
  - DOMAIN-SUFFIX,wx.qq.com,DIRECT
  - DOMAIN-SUFFIX,wxapp.qq.com,DIRECT
