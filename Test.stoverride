name: Test
desc: Test
version: 1.0

#!override

log-level: debug

dns: #!replace
  enable: true
  respect-rules: true
  ipv6: true
  prefer-h3: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  default-nameserver:
    - 1.1.1.1
    - 8.8.8.8
    - 2606:4700:4700::1111
    - 2606:4700:4700::1001
  nameserver:
    - https://dns.cloudflare.com/dns-query
    - https://dns.google/dns-query
    - https://dns.quad9.net/dns-query
  proxy-server-nameserver:
    - https://dns.google/dns-query
  direct-nameserver: []

  fallback:
    - https://dns.cloudflare.com/dns-query
    - https://dns.google/dns-query
    - https://dns.quad9.net/dns-query
  fallback-filter: {}

  fake-ip-filter:
    - '*.lan'
    - '*.local'
    - '*.msftconnecttest.com'
    - '*.msftncsi.com'
    - stun.*

profile: #!replace
  store-selected: true
  store-fake-ip: true

#-------------------#
# proxies:  #
#-------------------#
proxy-groups: #!replace
  - name: 🌐 All nodes
    type: select
    include-all: true

  - name: 🇺🇸 USA_Primary
    type: url-test
    include-all: true
    filter: '(?i)(\[US\]|^US$|USA|United States|\bUS\b|美国)'
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 50