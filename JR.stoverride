Name: USA Override 2.0
desc: |-
  Personal Stash Override
  远程规则集修复 + 美国组全面兜底
version: 1.1

#!override

mixed-port: 7890
allow-lan: true
bind-address: '*'
mode: rule
log-level: info
external-controller: ':9090'
unified-delay: true
tcp-concurrent: true

dns: #!replace
  enable: true
  respect-rules: true
  ipv6: false
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  
  default-nameserver:
    - 223.5.5.5
    - 119.29.29.29
    - 1.1.1.1

  nameserver:
    - 223.5.5.5
    - 119.29.29.29
    - https://doh.pub/dns-query
    - https://dns.alidns.com/dns-query

  proxy-server-nameserver:
    - 223.5.5.5
    - 119.29.29.29

  fallback:
    - https://dns.cloudflare.com/dns-query
    - https://dns.google/dns-query

  fallback-filter: {}

  fake-ip-filter:
    - '*.lan'
    - '*.local'
    - '*.msftconnecttest.com'
    - '*.msftncsi.com'
    # 锁定机场节点域名，防止解析死循环
    - 'pemby.ednovas.org'
    - 'shh.ysqhq.top'
    - 'dde.ysqhq.top'
    - stun.*

profile: #!replace
  store-selected: true
  store-fake-ip: true

proxy-groups: #!replace
  - name: 🌐 All nodes
    type: select
    include-all: true

  - name: 🇺🇸 USA_Primary
    type: url-test
    include-all: true
    filter: '(?i)(\[US\]|^US$|USA|United States|\bUS\b|美国)'
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 50

rules: #!replace
  # GitHub (优先保证规则集能下载)
  - DOMAIN-SUFFIX,github.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,githubusercontent.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,githubassets.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,raw.githubusercontent.com,🇺🇸 USA_Primary

  # 局域网与邮件
  - IP-CIDR,192.168.0.0/16,DIRECT,no-resolve
  - IP-CIDR,10.0.0.0/8,DIRECT,no-resolve
  - IP-CIDR,172.16.0.0/12,DIRECT,no-resolve
  - IP-CIDR,127.0.0.0/8,DIRECT,no-resolve
  - GEOIP,LAN,DIRECT,no-resolve
  - DST-PORT,465,DIRECT
  - DST-PORT,587,DIRECT
  - DST-PORT,993,DIRECT
  - DST-PORT,995,DIRECT

  # --- Apple 核心分流 ---
  - DOMAIN,time.apple.com,DIRECT
  - DOMAIN,captive.apple.com,DIRECT
  - DOMAIN-SUFFIX,music.apple.com,DIRECT
  - DOMAIN-SUFFIX,icloud.com,DIRECT
  - DOMAIN-SUFFIX,icloud-content.com,DIRECT
  - DOMAIN-SUFFIX,apple-cloudkit.com,DIRECT
  - DOMAIN,gateway.icloud.com,DIRECT
  
  # Apple 走代理部分
  - DOMAIN-SUFFIX,mzstatic.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,aaplimg.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,swcdn.apple.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,updates.cdn-apple.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,push.apple.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,push-apple.com.akadns.net,🇺🇸 USA_Primary
  - DOMAIN,itunes.apple.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,apps.apple.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,itunes.apple.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,appstore.com,🇺🇸 USA_Primary
  - DOMAIN-KEYWORD,buy.itunes,🇺🇸 USA_Primary
  - DOMAIN,bag.itunes.apple.com,🇺🇸 USA_Primary
  - DOMAIN,storekit.itunes.apple.com,🇺🇸 USA_Primary

  # Microsoft & Copilot
  - DOMAIN-KEYWORD,copilot,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,bing.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,bingapis.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,designer.microsoft.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,copilot.microsoft.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,ai.microsoft.com,🇺🇸 USA_Primary
  - DOMAIN,officeapps.live.com,🇺🇸 USA_Primary
  - DOMAIN,onedrive.live.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,1drv.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,sharepoint.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,office.net,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,office365.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,spoprod-a.akamaihd.net,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,mp.microsoft.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,xboxlive.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,storeedgefd.dsx.mp.microsoft.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,dl.delivery.mp.microsoft.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,displaycatalog.mp.microsoft.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,assets1.xboxlive.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,login.live.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,login.microsoftonline.com,🇺🇸 USA_Primary
  - DOMAIN-SUFFIX,account.live.com,🇺🇸 USA_Primary
  - DOMAIN,storage.live.com,DIRECT
  - DOMAIN-KEYWORD,skyapi,DIRECT
  - DOMAIN-SUFFIX,onedrive.com,DIRECT
  - DOMAIN-SUFFIX,outlook.com,DIRECT
  - DOMAIN-SUFFIX,office.com,DIRECT
  - DOMAIN-SUFFIX,msauth.net,DIRECT

  # Tiktok / 字节跳动
  - DOMAIN-KEYWORD,snssdk,🇺🇸 USA_Primary
  - DOMAIN-KEYWORD,amemv,🇺🇸 USA_Primary
  - DOMAIN-KEYWORD,douyin,🇺🇸 USA_Primary
  - DOMAIN-KEYWORD,byteimg,🇺🇸 USA_Primary
  - DOMAIN-KEYWORD,pstatp,🇺🇸 USA_Primary
  - DOMAIN-KEYWORD,bytedance,🇺🇸 USA_Primary

  # 远程规则集
  - RULE-SET,Privacy,REJECT
  - RULE-SET,ChinaMax,DIRECT

  # 底部兜底策略（已修改为默认美国节点）
  - GEOIP,LAN,DIRECT
  - GEOIP,CN,DIRECT,no-resolve
  - MATCH,🇺🇸 USA_Primary

rule-providers: #!replace
  ChinaMax:
    behavior: domain
    format: yaml
    interval: 86400
    url: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/ChinaMax/ChinaMax_Domain.yaml

  Privacy:
    behavior: domain
    format: yaml
    interval: 86400
    url: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Privacy/Privacy_Domain.yaml
